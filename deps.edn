{:paths ["src" "resources"]
 :deps {io.github.kotoba-lang/security {:git/url "https://github.com/kotoba-lang/security.git"
                                        :git/sha "9316629ed15437ef1cf0f93b7f98e7cb31ef91d2"}
        com.dylibso.chicory/wasm {:mvn/version "1.4.0"}
        com.dylibso.chicory/runtime {:mvn/version "1.4.0"}}
 :aliases
  {:test {:extra-paths ["test"]
          :jvm-opts ["--enable-native-access=ALL-UNNAMED"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}

   :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.10"}}
           :ns-default build}

  ;; ADR-0014 V0: run the self-owned VMM ("hvt tender") KVM boot spike.
  ;; Needs a real /dev/kvm (Linux) and FFM native access. Prints an EDN run
  ;; receipt on stdout; exit 0 iff the guest emitted "HI\n" and requested
  ;; PSCI SYSTEM_OFF. Verified by `scripts/hvt-smoke.cljs`.
  :hvt {:jvm-opts ["--enable-native-access=ALL-UNNAMED"]
        :main-opts ["-m" "aiueos.hvt"]}

  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
