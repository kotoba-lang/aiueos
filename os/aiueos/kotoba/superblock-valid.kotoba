(defn read-u32 [base length index]
  (+ (kernel-load-u8 base length index)
     (* (kernel-load-u8 base length (+ index 1)) 256)
     (* (kernel-load-u8 base length (+ index 2)) 65536)
     (* (kernel-load-u8 base length (+ index 3)) 16777216)))

(defn fnv-step [base length index hash]
  (if (= index length) hash
    (fnv-step base length (+ index 1)
      (* (bit-xor hash (kernel-load-u8 base length index)) 16777619))))

(defn fnv [base length]
  (bit-and (fnv-step base length 0 2166136261) 4294967295))

(defn aiueos-superblock-valid [base length]
  (let [object-offset (read-u32 base length 24)
        object-length (read-u32 base length 28)]
    (and (= length 512)
         (= (read-u32 base length 0) 1163217217)
         (= (read-u32 base length 4) 3232582)
         (= (read-u32 base length 8) 1)
         (= (read-u32 base length 12) 36)
         (= (read-u32 base length 16) 1)
         (> object-length 0)
         (>= object-offset 36)
         (<= object-offset 512)
         (<= object-length (- 512 object-offset))
         (= (fnv (+ base object-offset) object-length)
            (read-u32 base length 32)))))

(defn main [] 0)
