(defn aiueos-fnv1a-step [base length index hash]
  (if (= index length)
    hash
    (aiueos-fnv1a-step
      base
      length
      (+ index 1)
      (* (bit-xor hash (kernel-load-u8 base length index)) 16777619))))

(defn aiueos-fnv1a [base length]
  (aiueos-fnv1a-step base length 0 2166136261))

(defn main [] 0)
