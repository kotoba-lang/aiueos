(ns aiueos.user-elf-valid)

(defn u8 [image length offset]
  (kernel-load-u8-16k image length offset))

(defn u16 [image length offset]
  (+ (u8 image length offset) (* (u8 image length (+ offset 1)) 256)))

(defn u32 [image length offset]
  (+ (u16 image length offset) (* (u16 image length (+ offset 2)) 65536)))

(defn zero32 [image length offset] (= (u32 image length offset) 0))

(defn segment [image length base flags filesz]
  (let [offset (if (= base 64) 4096 8192)
        address (if (= base 64) 1970176 1974272)]
  (and (= (u32 image length base) 1)
       (= (u32 image length (+ base 4)) flags)
       (= (u32 image length (+ base 8)) offset)
       (zero32 image length (+ base 12))
       (= (u32 image length (+ base 16)) address)
       (zero32 image length (+ base 20))
       (= (u32 image length (+ base 24)) address)
       (zero32 image length (+ base 28))
       (= (u32 image length (+ base 32)) filesz)
       (zero32 image length (+ base 36))
       (= (u32 image length (+ base 40)) filesz)
       (zero32 image length (+ base 44))
       (= (u32 image length (+ base 48)) 4096)
       (zero32 image length (+ base 52)))))

(defn context-zero [image length index end]
  (if (= index end) 1
    (and (= (u8 image length index) 0)
         (context-zero image length (+ index 1) end))))

(defn aiueos-user-elf-valid [image length]
  (let [text-size (u32 image length 96)]
    (and (>= length 8280)
         (<= length 12288)
         (= (u32 image length 0) 1179403647)
         (= (u8 image length 4) 2)
         (= (u8 image length 5) 1)
         (= (u8 image length 6) 1)
         (= (u16 image length 16) 2)
         (= (u16 image length 18) 62)
         (= (u32 image length 20) 1)
         (= (u32 image length 24) 1970176)
         (zero32 image length 28)
         (= (u32 image length 32) 64)
         (zero32 image length 36)
         (= (u16 image length 52) 64)
         (= (u16 image length 54) 56)
         (= (u16 image length 56) 2)
         (> text-size 0)
         (<= text-size 4096)
         (<= text-size (- length 4096))
         (segment image length 64 5 text-size)
         (segment image length 120 6 88)
         (= (u32 image length 8192) 0)
         (zero32 image length 8196)
         (= (u32 image length 8200) 256)
         (zero32 image length 8204)
         (= (u8 image length 8208) 60)
         (context-zero image length 8209 8240)
         (= (u32 image length 8240) 1970208)
         (zero32 image length 8244)
         (context-zero image length 8248 8272)
         (= (u32 image length 8272) 0)
         (zero32 image length 8276))))

(defn main [] 0)
