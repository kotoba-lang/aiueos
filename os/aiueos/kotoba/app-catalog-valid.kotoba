(ns aiueos.app-catalog-valid)

;; Authenticated aiuefs-v3 application-catalog policy. The caller verifies the
;; catalog digest/signature first; this function then admits only the canonical
;; bounded layout and rejects every extent/signature/identity collision.

(defn load32le [catalog length offset]
  (+ (kernel-load-u8 catalog length offset)
     (+ (* (kernel-load-u8 catalog length (+ offset 1)) 256)
        (+ (* (kernel-load-u8 catalog length (+ offset 2)) 65536)
           (* (kernel-load-u8 catalog length (+ offset 3)) 16777216)))))

(defn magic-byte [index]
  (if (= index 0) 65 (if (= index 1) 73 (if (= index 2) 85
  (if (= index 3) 67 (if (= index 4) 65 (if (= index 5) 84
  (if (= index 6) 49 0))))))))

(defn magic-valid [catalog length index]
  (if (= index 8) 1
    (if (= (kernel-load-u8 catalog length index) (magic-byte index))
      (magic-valid catalog length (+ index 1)) 0)))

(defn id-valid [catalog length base index ended]
  (if (= index 16) ended
    (let [value (kernel-load-u8 catalog length (+ base index))]
      (if (= ended 1)
        (if (= value 0) (id-valid catalog length base (+ index 1) 1) 0)
        (if (= value 0)
          (if (= index 0) 0 (id-valid catalog length base (+ index 1) 1))
          (if (< value 33) 0
            (if (> value 126) 0
              (id-valid catalog length base (+ index 1) 0))))))))

(defn in-extent [sector start end]
  (if (>= sector start) (if (< sector end) 1 0) 0))

(defn entry-sector [catalog length app]
  (load32le catalog length (+ 32 (* app 64))))
(defn entry-length [catalog length app]
  (load32le catalog length (+ 36 (* app 64))))
(defn entry-signature-sector [catalog length app]
  (load32le catalog length (+ 72 (* app 64))))
(defn entry-signer [catalog length app]
  (load32le catalog length (+ 76 (* app 64))))
(defn entry-end [catalog length app]
  (+ (entry-sector catalog length app)
     (quot (+ (entry-length catalog length app) 511) 512)))

(defn ids-different [catalog length current prior state]
  (let [difference (quot state 32)
        index (- state (* difference 32))]
    (if (= index 16) difference
      (let [next-difference
             (+ difference
                (bit-xor (kernel-load-u8 catalog length (+ 16 (+ (* current 64) index)))
                         (kernel-load-u8 catalog length (+ 16 (+ (* prior 64) index)))))]
        (ids-different catalog length current prior
                       (+ (+ index 1) (* next-difference 32)))))))

(defn prior-valid [catalog length current prior]
  (if (= prior current) 1
    (let [current-sector (entry-sector catalog length current)
          current-end (entry-end catalog length current)
          current-signature (entry-signature-sector catalog length current)
          prior-sector (entry-sector catalog length prior)
          prior-end (entry-end catalog length prior)
          prior-signature (entry-signature-sector catalog length prior)]
      (if (= (ids-different catalog length current prior 0) 0) 0
        (if (= current-signature prior-signature) 0
          (if (= (in-extent current-signature prior-sector prior-end) 1) 0
            (if (= (in-extent prior-signature current-sector current-end) 1) 0
              (if (and (< current-sector prior-end) (< prior-sector current-end)) 0
                (prior-valid catalog length current (+ prior 1))))))))))

(defn entry-valid [catalog length capacity routing app]
  (let [base (+ 16 (* app 64))
        catalog-sector (load32le routing 8 0)
        catalog-signature (load32le routing 8 4)
        sector (entry-sector catalog length app)
        object-length (entry-length catalog length app)
        end (entry-end catalog length app)
        signature (entry-signature-sector catalog length app)]
    (if (= (id-valid catalog length base 0 0) 0) 0
      (if (< sector 4) 0
        (if (= object-length 0) 0
          (if (> object-length 12288) 0
            (if (> end capacity) 0
              (if (< signature end) 0
                (if (>= signature capacity) 0
                  (if (not (= (entry-signer catalog length app) 1)) 0
                    (if (= (in-extent catalog-sector sector end) 1) 0
                      (if (= (in-extent catalog-signature sector end) 1) 0
                        (if (= signature catalog-sector) 0
                          (if (= signature catalog-signature) 0
                            (prior-valid catalog length app 0)))))))))))))))

(defn entries-valid [catalog length capacity routing app]
  (let [count (load32le catalog length 12)]
  (if (= app count) 1
    (if (= (entry-valid catalog length capacity routing app) 1)
      (entries-valid catalog length capacity routing (+ app 1))
      0))))

(defn aiueos-app-catalog-valid [catalog length capacity routing routing-length]
  (if (< length 80) 0
    (if (> length 272) 0
      (if (not (= routing-length 8)) 0
        (if (= (magic-valid catalog length 0) 0) 0
          (if (not (= (load32le catalog length 8) 1)) 0
            (let [count (load32le catalog length 12)]
              (if (< count 1) 0
                (if (> count 4) 0
                  (if (not (= length (+ 16 (* count 64)))) 0
                    (entries-valid catalog length capacity routing 0)))))))))))

(defn main [] 0)
