[{:db/id -1, :aiueos.cli.contract/version 1, :aiueos.cli.contract/scope "{:owner :aiueos, :authority :cljc-edn, :host-adapter-targets [:rust :jvm :node :native], :description \"Data-first command contract for the aiueos capability-OS CLI, mirroring kotoba-lang/kotoba-lang's lang/cli.edn pattern (ADR-2607022200). Host CLIs are adapters; they consume this contract and aiueos.cli/dispatch instead of defining command semantics independently. Retired Rust source: aiueos/src/bin/aiueos.rs.\"}", :aiueos.cli.contract/coverage-labels "{:full {:label \"full\", :meaning \"Computed entirely by the CLJC authority (aiueos.broker/aiueos.graph/aiueos.surface/aiueos.audit) -- no wasmtime, no wasm-byte execution.\"}, :decision-only {:label \"decision-only\", :meaning \"The CLJC authority computes the grant/deny decision; on :grant, executing the component is a native host-adapter concern (ADR-2607022200 Layer 3).\"}, :adapter-only {:label \"adapter-only\", :meaning \"No CLJC decision role at all -- delegates to kototama/kotoba-clj (source compilation/safety), or is inherently native (VM/initramfs provisioning, private-key signing tooling).\"}}", :aiueos.cli.contract/option-types "{:boolean {:description \"Presence flag or explicit boolean value.\"}, :string {:description \"Single string argument.\"}, :path {:description \"Filesystem path interpreted by the host adapter.\"}, :edn {:description \"EDN value or path to an EDN document, as specified by the option.\"}, :enum {:description \"One value from the option's :values vector.\"}, :int {:description \"Integer value.\"}}", :aiueos.cli.contract/commands "[{:id :verify, :coverage :full, :summary \"Capability + policy check for a manifest or system.\", :positionals [{:id :target, :type :path, :required? true, :description \"A single manifest EDN file, or a system.aiueos.edn (:aiueos/components) file.\"}], :options [{:id :policy, :flags [\"--policy\"], :type :path, :description \"Deployment policy overlay EDN (aiueos.contract/validate-deployment-policy shape).\"} {:id :edn, :flags [\"--edn\"], :type :boolean, :description \"Emit machine-readable EDN result (aiueos.contract/validate-policy-decision shape).\"}]} {:id :inspect, :coverage :full, :summary \"Print the capability graph for a system.\", :positionals [{:id :system, :type :path, :required? true, :description \"A system.aiueos.edn file.\"}], :options [{:id :policy, :flags [\"--policy\"], :type :path, :description \"Deployment policy overlay EDN.\"} {:id :dot, :flags [\"--dot\"], :type :boolean, :description \"Emit Graphviz dot instead of EDN.\"} {:id :edn, :flags [\"--edn\"], :type :boolean, :description \"Emit machine-readable EDN (providers map + boot order + depths).\"}]} {:id :surface, :coverage :full, :summary \"Inspect a deployment surface's offered capabilities (ADR-0005/ADR-0007).\", :subcommands [:inspect], :options [{:id :id, :flags [\"--id\"], :type :enum, :values [:robot :browser :cloud :computer-virtual :computer-vm :computer-host], :required? true, :description \"Surface id.\"} {:id :edn, :flags [\"--edn\"], :type :boolean, :description \"Emit machine-readable EDN.\"}]} {:id :audit, :coverage :full, :summary \"Replay/query the append-only audit log.\", :options [{:id :log, :flags [\"--log\"], :type :path, :description \"Audit log path; defaults to .aiueos/audit.edn under the current directory (aiueos.audit/log-path).\"} {:id :event, :flags [\"--event\"], :type :enum, :values [:grant :deny :compile :run :reject], :description \"Filter to one event kind.\"} {:id :component, :flags [\"--component\"], :type :string, :description \"Filter to one component id.\"} {:id :edn, :flags [\"--edn\"], :type :boolean, :description \"Emit machine-readable EDN.\"}]} {:id :admit, :coverage :decision-only, :summary \"Code-as-data admission gate for an agent-submitted component (ADR-0004).\", :positionals [{:id :manifest, :type :path, :required? true, :description \"The agent-submitted component manifest. Trust is floored to :ai-generated before verification -- it can never grant itself trust.\"}], :options [{:id :policy, :flags [\"--policy\"], :type :path, :description \"Deployment policy overlay EDN.\"} {:id :system, :flags [\"--system\"], :type :path, :description \"System file supplying the capability graph the manifest is checked against.\"} {:id :edn, :flags [\"--edn\"], :type :boolean, :description \"Emit machine-readable EDN. On :grant, executing the component is a native host-adapter concern.\"}]} {:id :run, :coverage :decision-only, :summary \"Verify then execute a single component's entry point.\", :positionals [{:id :manifest, :type :path, :required? true}], :options [{:id :policy, :flags [\"--policy\"], :type :path} {:id :system, :flags [\"--system\"], :type :path} {:id :surface, :flags [\"--surface\"], :type :string} {:id :edn, :flags [\"--edn\"], :type :boolean}]} {:id :up, :coverage :decision-only, :summary \"Boot an entire system: link, verify, then launch every component in dependency order.\", :positionals [{:id :system, :type :path, :required? true}], :options [{:id :policy, :flags [\"--policy\"], :type :path} {:id :rounds, :flags [\"--rounds\"], :type :int, :default 1} {:id :edn, :flags [\"--edn\"], :type :boolean}]} {:id :sign, :coverage :adapter-only, :summary \"ed25519-sign the (component-id, wasm-sha256) binding with a private key (ADR-0003). Key custody is tooling, not the CLJC authority or the runtime -- see aiueos.signing's namespace docstring. aiueos.signing/verify is the corresponding read-side check, and IS CLJC authority.\", :positionals [{:id :manifest, :type :path, :required? true}], :options [{:id :key, :flags [\"--key\"], :type :string, :required? true, :description \"Hex ed25519 private key seed.\"} {:id :edn, :flags [\"--edn\"], :type :boolean}]} {:id :check, :coverage :adapter-only, :summary \"Safe-kotoba subset gate over a source file. Delegates to kototama/kotoba-clj (kotoba-lang/kotoba's src/kotoba/runtime.clj) -- NOT an aiueos-owned check. See kotoba-lang/kotoba's ADR-kotoba-shell-aiueos-safety-clj.md.\", :positionals [{:id :source, :type :path, :required? true}], :options []} {:id :compile, :coverage :adapter-only, :summary \"Compile CLJ/Kotoba source (or a manifest's :aiueos/source) to wasm. Delegates to kototama/kotoba-clj -- NOT an aiueos-owned check.\", :positionals [{:id :input, :type :path, :required? true}], :options [{:id :output, :flags [\"-o\"], :type :path}]} {:id :hash, :coverage :adapter-only, :summary \"sha256 of a file, for pinning :aiueos/wasm-sha256. Trivial content hashing over file bytes; no aiueos decision logic involved.\", :positionals [{:id :file, :type :path, :required? true}], :options [{:id :edn, :flags [\"--edn\"], :type :boolean}]} {:id :image, :coverage :adapter-only, :summary \"Build an initramfs image for a system. Purely native/host -- no CLJC role.\", :subcommands [:build], :options [{:id :aiueos-bin, :flags [\"--aiueos-bin\"], :type :path, :required? true} {:id :policy, :flags [\"--policy\"], :type :path} {:id :out, :flags [\"--out\"], :type :path} {:id :dry-run, :flags [\"--dry-run\"], :type :boolean} {:id :edn, :flags [\"--edn\"], :type :boolean}]} {:id :vm, :coverage :adapter-only, :summary \"Provision or boot a VM running a system. Purely native/host -- no CLJC role.\", :subcommands [:up :boot], :options [{:id :policy, :flags [\"--policy\"], :type :path} {:id :name, :flags [\"--name\"], :type :string} {:id :provider, :flags [\"--provider\"], :type :enum, :values [:auto :lima]} {:id :kernel, :flags [\"--kernel\"], :type :path} {:id :aiueos-bin, :flags [\"--aiueos-bin\"], :type :path} {:id :block, :flags [\"--block\"], :type :path} {:id :console, :flags [\"--console\"], :type :enum, :values [:pl011 :virtio-console]} {:id :dry-run, :flags [\"--dry-run\"], :type :boolean} {:id :edn, :flags [\"--edn\"], :type :boolean}]}]"}]